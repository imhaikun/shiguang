# ── 本地开发环境（Express 后端） ──
# 邮件服务配置（用于忘记密码功能）
# 以 QQ 邮箱为例：
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=587
# SMTP_USER=你的QQ邮箱@qq.com
# SMTP_PASS=你的QQ邮箱授权码

SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=imloyo@qq.com
SMTP_PASS=ouavnncapnsfcbcj

# ── 前端 API 基础地址（生产环境部署时配置） ──
# Cloudflare Pages 环境变量：设置为你的 Worker URL
# 例如：VITE_API_BASE_URL=https://shiguang-api.yourname.workers.dev
# 本地开发留空即可（走 Vite 代理）
VITE_API_BASE_URL=

